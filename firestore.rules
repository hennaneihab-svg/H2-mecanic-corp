rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Public slots — readable by everyone (to show booked times in the calendar)
    match /public_slots/{slotId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // 2. Full appointments — anyone can create (book a slot),
    //    but reading is open so the admin page can access without Firebase Auth.
    //    NOTE: The admin page is password-protected client-side.
    match /appointments/{appointmentId} {
      allow read, create, update: if true;
      allow delete: if false;
    }
  }
}
